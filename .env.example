# Copy this file to ".env" and fill in your real values.
# Never share this file or commit it to a public code repository.

# A long, random string used to secure admin logins. Change this to anything random.
SECRET_KEY=please-change-this-to-a-long-random-string

# Set to "true" only while testing locally, never on the live site.
DEBUG=false

# --- Razorpay (get these from https://dashboard.razorpay.com/app/keys) ---
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# --- Razorpay webhooks (recommended for payment reliability) ---
# Set this to the webhook secret from Razorpay Dashboard -> Settings -> Webhooks.
# When set, the /webhook/razorpay endpoint independently confirms payments
# server-side, so a crashed browser tab doesn't leave a customer charged
# with no order confirmation.
RAZORPAY_WEBHOOK_SECRET=

# --- First-run admin login (only used the very first time the site starts) ---
# If you leave ADMIN_PASSWORD blank, a random one is generated for you on
# first startup and saved to instance/INITIAL_ADMIN_PASSWORD.txt — check
# there, log in once, then set your own password immediately.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# --- Optional: lets the site email customers automatically. Leave blank to skip. ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=

# --- Optional but recommended: transactional email via HTTP API instead of SMTP. ---
# If set, these are tried before SMTP above (Resend first, then SendGrid).
# Resend: https://resend.com (free tier, no sending domain required to start).
# SendGrid: https://sendgrid.com (free tier: 100 emails/day).
RESEND_API_KEY=
SENDGRID_API_KEY=
EMAIL_FROM=
EMAIL_FROM_NAME=

# --- Optional: Firebase Phone Authentication (SMS OTP sign-in / account creation) ---
# Lets customers verify their phone with a one-time code from the homepage or
# at checkout. Leave FIREBASE_API_KEY blank to disable — the site works fine
# as guest-checkout-only without it.
# Setup (5 minutes): console.firebase.google.com -> Create project ->
#   Build -> Authentication -> Sign-in method -> enable "Phone" ->
#   Project settings -> General -> "Your apps" -> Add app (Web, </>) ->
#   copy the values below from the firebaseConfig snippet shown.
# Also add your site's domain under Authentication -> Settings -> Authorized domains.
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_APP_ID=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_STORAGE_BUCKET=

# --- Optional: Cloudflare Turnstile CAPTCHA (free, no request limits) ---
# Protects admin login, checkout, and newsletter signup from bots/abuse.
# Get free keys at https://dash.cloudflare.com/ -> Turnstile. Leave blank to disable.
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# --- OTP verification ---
# ⚠️  IMPORTANT: OTP_DEV_MODE defaults to false. Set to "true" ONLY for local
# testing — when true, the OTP code is returned in the API response so you can
# test the phone login flow without an SMS provider. NEVER set this to "true"
# on a live/production deployment — it would let anyone log in as anyone.
OTP_DEV_MODE=false
OTP_EXPIRY_MINUTES=5

# --- Optional: Turso remote database (replaces local SQLite file) ---
# If set, the app uses a remote Turso database instead of a local .db file.
# Get these from https://app.turso.tech -> your database -> Settings.
# The URL should be in libsql:// or https:// format, e.g.:
#   TURSO_DB_URL=libsql://your-db-yourorg.turso.io
# (wss:// URLs are auto-converted to libsql:// — no need to change old values.)
TURSO_DB_URL=
TURSO_DB_AUTH_TOKEN=
